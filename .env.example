APP_NAME="SagaChap"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sagachap
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -----------------------------------------------------------
# CONFIGURATION EMAIL
# -----------------------------------------------------------
# Par défaut "log" = les emails sont écrits dans storage/logs/laravel.log
# Pour les envoyer vraiment, choisir un des exemples ci-dessous
# -----------------------------------------------------------

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@sagachap.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Option 1 : SMTP Gmail ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@gmail.com
# MAIL_PASSWORD=votre_mot_de_passe_application
# MAIL_ENCRYPTION=tls

# --- Option 2 : Mailtrap (tests) ---
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=votre_username_mailtrap
# MAIL_PASSWORD=votre_password_mailtrap
# MAIL_ENCRYPTION=tls

# --- Option 3 : Brevo / Sendinblue ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@email.com
# MAIL_PASSWORD=votre_cle_api_brevo
# MAIL_ENCRYPTION=tls

# -----------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"
